{
  "name": "i-stoedet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test 'test/**/*.test.mjs' 'scripts/**/*.test.mjs'",
    "dev": "eleventy --serve",
    "build": "eleventy",
    "clean": "rm -rf _site",
    "deploy": "npm run build && rsync -avz --delete _site/ root@websites:/var/www/xn--i-stdet-t1a.dk/current/ && npm run deploy:purge && npm run verify:live",
    "deploy:caddy": "bash scripts/deploy-caddy.sh",
    "verify:live": "node scripts/verify-live.mjs",
    "cap:assets": "node scripts/build-www.mjs",
    "cap:icons": "node scripts/make-assets.mjs && npx @capacitor/assets generate --ios",
    "cap:sync": "npm run cap:assets && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios:release": "sh scripts/ios-release.sh",
    "xcode:log": "node scripts/xcode-cloud-log.mjs",
    "deploy:purge": "node scripts/purge-cache.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@udstillerguide/11ty-media": "file:../../ug-11ty-plugins/packages/media",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "sharp": "^0.35.1"
  }
}
